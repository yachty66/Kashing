DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
PUBLIC_BASE_URL=http://localhost:3001

GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Finverse (Hong Kong / Asia banks). Get these from https://docs.finverse.com
# and register PUBLIC_BASE_URL + /api/connect/callback as a redirect_uri.
# Optional: set FINVERSE_BASE_URL to a sandbox host.
FINVERSE_CLIENT_ID=
FINVERSE_CLIENT_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- WhatsApp CFO agent (Twilio) ------------------------------------------
# From the Twilio console. TWILIO_WHATSAPP_FROM is the sandbox/sender number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional model overrides for the agent.
AGENT_MODEL=anthropic/claude-sonnet-4.6   # tool-calling chat
VISION_MODEL=google/gemini-2.5-flash      # receipt OCR

# Demo merchant FPS ID for generated payment QR codes (7 or 9 digits).
FPS_MERCHANT_ID=1029384

# Demo users, seeded by `npm run seed`. E.164, no "whatsapp:" prefix.
MANAGER_PHONE=+85291234567
MANAGER_NAME=Alex (Manager)
EMPLOYEE_PHONE=+85298765432
EMPLOYEE_NAME=Sam (Employee)
